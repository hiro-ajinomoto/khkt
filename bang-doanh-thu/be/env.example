# Dùng 8010 để chạy song song với backend KHKT (8000).
PORT=8010
# CORS_ORIGIN=http://localhost:5173

# Bắt buộc trên production — ký JWT đăng nhập (vd. openssl rand -hex 32).
JWT_SECRET=
# Tuỳ chọn, mặc định 7d
# JWT_EXPIRES_IN=7d

# Giống backend KHKT (`be/.env`): cùng cluster, có thể cùng DB hoặc khác DB.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=khkt_math_grader
# Trả nợ — tên (collection bang_doanh_thu_people): BE tạo index `nameNorm` khi khởi động;
# mỗi bản ghi có thể có nickname, phone (chữ số, rỗng nếu chỉ thêm từ ô bảng).
